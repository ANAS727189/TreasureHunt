              </xsl:attribute>
              <a href="{loc}">
                <xsl:value-of select="loc"/>
              </a>
              <div class="metadata">
                <span>Last Modified: <xsl:value-of select="lastmod"/></span>
                <span class="priority">Priority: <xsl:value-of select="priority"/></span>
              </div>
            </div>
          </xsl:for-each>
        </body>
      </html>
    </xsl:template>
  </xsl:stylesheet>

