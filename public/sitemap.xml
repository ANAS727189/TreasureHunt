            }
            .metadata {
              font-size: 0.875rem;
              color: #888;
              display: flex;
              justify-content: space-between;
            }
            .high-priority {
              border-color: #fbbf24;
            }
            .priority {
              color: #fbbf24;
            }
          </style>
        </head>
        <body>
          <h1>Sitemap - Kya Tumhe Naukri Milegi?</h1>
          <xsl:for-each select="urlset/url">
            <div>
              <xsl:attribute name="class">
                url-entry
